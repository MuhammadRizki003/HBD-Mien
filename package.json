{
  "name": "happy-birthday",
  "version": "1.0.0",
  "description": "An app that let's you say happy birthday to your friend in a nerdy way.",
  "main": "index.js",
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "babel-loader": "^10.1.1",
    "browser-sync": "^3.0.4",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.4",
    "html-webpack-plugin": "^5.6.6",
    "run-script-os": "^1.0.2",
    "style-loader": "^4.0.0",
    "vite": "^8.0.3",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.3",
    "webpack-merge": "^6.0.1"
  },
  "scripts": {
    "start": "run-script-os",
    "start:win32": "browser-sync start --server --files '**/*.css, **/*.html, **/*.js, !node_modules/**/*' --directory --port 7777 --browser \"C:\\Program Files\\Firefox Developer Edition\\firefox.exe\"",
    "//": "Hello! If you are having trouble running this command. Try changing Firefox Developer Edition to FirefoxDeveloperEdition",
    "start:darwin:linux": "browser-sync start --server --files '**/*.css, **/*.html, **/*.js, !node_modules/**/*' --directory --port 7777",
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "vite",
    "start-dev": "webpack serve --config webpack.dev.js",
    "build": "webpack --config webpack.prod.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ksonone/happy-birthday.git"
  },
  "keywords": [
    "Happy",
    "Birthday"
  ],
  "author": "Kapil H. Sonone",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ksonone/happy-birthday/issues"
  },
  "homepage": "https://github.com/ksonone/happy-birthday#readme",
  "dependencies": {
    "regenerator-runtime": "^0.14.1",
    "sweetalert2": "^11.26.24"
  }
}
